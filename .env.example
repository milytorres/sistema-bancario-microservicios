# Copiar este archivo a ".env" (no versionado) y ajustar valores reales antes de ejecutar
# "docker compose up". Si no se provee un .env, docker-compose.yml usa estos mismos defaults.

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME_CLIENTE=banco_cliente
DB_NAME_CUENTA=banco_cuenta

# Origen permitido por CORS en ambos microservicios (URL del frontend Angular).
# En local: http://localhost:4200. En producción: la URL real de Netlify/Vercel.
FRONTEND_URL=http://localhost:4200
